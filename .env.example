# Firebase config — copy to `.env.local` and fill in from your Firebase project.
# In the Firebase console: Project Settings → Your apps → Web app → SDK setup.
#
# If these are blank/missing, the app runs in LOCAL-ONLY mode (no auth, no cloud
# sync, no leaderboards) and shows a banner saying so.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
